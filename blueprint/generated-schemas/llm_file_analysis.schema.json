{
  "properties": {
    "prompt": {
      "description": "What to extract or analyze from the file(s).",
      "title": "Prompt",
      "type": "string"
    },
    "llm_conn_id": {
      "description": "Airflow connection ID for the model provider.",
      "title": "Llm Conn Id",
      "type": "string"
    },
    "file_path": {
      "description": "File location, e.g. `s3://bucket/data.csv` or a local path.",
      "title": "File Path",
      "type": "string"
    },
    "file_conn_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Connection ID for the object store holding the file.",
      "title": "File Conn Id"
    },
    "multi_modal": {
      "default": false,
      "description": "Attach images/PDFs as binary for multi-modal analysis.",
      "title": "Multi Modal",
      "type": "boolean"
    },
    "sample_rows": {
      "default": 10,
      "description": "Rows to sample from tabular files.",
      "minimum": 1,
      "title": "Sample Rows",
      "type": "integer"
    },
    "max_files": {
      "default": 20,
      "description": "Maximum number of files to analyze.",
      "minimum": 1,
      "title": "Max Files",
      "type": "integer"
    },
    "system_prompt": {
      "default": "",
      "description": "Optional instructions for the analysis.",
      "title": "System Prompt",
      "type": "string"
    },
    "model_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Override the connection's model.",
      "title": "Model Id"
    },
    "blueprint": {
      "type": "string",
      "const": "llm_file_analysis",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Steps that must complete before this step runs",
      "default": []
    },
    "trigger_rule": {
      "type": "string",
      "enum": [
        "all_done",
        "all_done_setup_success",
        "all_failed",
        "all_skipped",
        "all_success",
        "always",
        "none_failed",
        "none_failed_min_one_success",
        "none_skipped",
        "one_done",
        "one_failed",
        "one_success"
      ],
      "description": "Trigger rule for this step (default: all_success)"
    }
  },
  "required": [
    "blueprint",
    "version",
    "prompt",
    "llm_conn_id",
    "file_path"
  ],
  "title": "llm_file_analysis",
  "type": "object",
  "templateType": "blueprint",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
