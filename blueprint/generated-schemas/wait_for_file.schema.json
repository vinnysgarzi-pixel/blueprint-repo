{
  "properties": {
    "filepath": {
      "description": "Path (or glob) to wait for, relative to the connection's root.",
      "title": "Filepath",
      "type": "string"
    },
    "fs_conn_id": {
      "default": "fs_default",
      "description": "Filesystem connection ID defining the root path.",
      "title": "Fs Conn Id",
      "type": "string"
    },
    "poke_interval": {
      "default": 60,
      "description": "Seconds between checks.",
      "minimum": 1,
      "title": "Poke Interval",
      "type": "integer"
    },
    "timeout": {
      "default": 86400,
      "description": "Seconds to wait before the sensor times out and fails.",
      "minimum": 1,
      "title": "Timeout",
      "type": "integer"
    },
    "mode": {
      "default": "reschedule",
      "description": "`reschedule` frees the worker slot between checks (recommended for long waits).",
      "enum": [
        "poke",
        "reschedule"
      ],
      "title": "Mode",
      "type": "string"
    },
    "blueprint": {
      "type": "string",
      "const": "wait_for_file",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Steps that must complete before this step runs",
      "default": []
    },
    "trigger_rule": {
      "type": "string",
      "enum": [
        "all_done",
        "all_done_setup_success",
        "all_failed",
        "all_skipped",
        "all_success",
        "always",
        "none_failed",
        "none_failed_min_one_success",
        "none_skipped",
        "one_done",
        "one_failed",
        "one_success"
      ],
      "description": "Trigger rule for this step (default: all_success)"
    }
  },
  "required": [
    "blueprint",
    "version",
    "filepath"
  ],
  "title": "wait_for_file",
  "type": "object",
  "templateType": "blueprint",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
