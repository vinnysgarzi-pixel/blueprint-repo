{
  "properties": {
    "conn_id": {
      "description": "Airflow connection ID for the target database.",
      "title": "Conn Id",
      "type": "string"
    },
    "table_name": {
      "description": "Destination table name.",
      "title": "Table Name",
      "type": "string"
    },
    "rows": {
      "description": "Rows to insert. This field is templated \u2014 usually an XCom reference resolving to a list of row tuples, e.g. `{{ ti.xcom_pull(task_ids='extract') }}`.",
      "title": "Rows",
      "type": "string"
    },
    "db_schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional schema for the destination table.",
      "title": "Db Schema"
    },
    "columns": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional explicit column names for the insert.",
      "title": "Columns"
    },
    "blueprint": {
      "type": "string",
      "const": "sql_insert_rows",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Steps that must complete before this step runs",
      "default": []
    },
    "trigger_rule": {
      "type": "string",
      "enum": [
        "all_done",
        "all_done_setup_success",
        "all_failed",
        "all_skipped",
        "all_success",
        "always",
        "none_failed",
        "none_failed_min_one_success",
        "none_skipped",
        "one_done",
        "one_failed",
        "one_success"
      ],
      "description": "Trigger rule for this step (default: all_success)"
    }
  },
  "required": [
    "blueprint",
    "version",
    "conn_id",
    "table_name",
    "rows"
  ],
  "title": "sql_insert_rows",
  "type": "object",
  "templateType": "blueprint",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
