{
  "properties": {
    "conn_id": {
      "description": "Airflow connection ID for the target database, e.g. `snowflake_default`.",
      "title": "Conn Id",
      "type": "string"
    },
    "sql": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "SQL to run inline. Provide either `sql` or `sql_file`.",
      "title": "Sql"
    },
    "sql_file": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Path to a `.sql` file (resolved via the DAG template search path). Provide either `sql` or `sql_file`.",
      "title": "Sql File"
    },
    "autocommit": {
      "default": true,
      "description": "Commit each statement automatically.",
      "title": "Autocommit",
      "type": "boolean"
    },
    "split_statements": {
      "default": true,
      "description": "Split the SQL on `;` and run each statement separately.",
      "title": "Split Statements",
      "type": "boolean"
    },
    "blueprint": {
      "type": "string",
      "const": "run_sql",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Steps that must complete before this step runs",
      "default": []
    },
    "trigger_rule": {
      "type": "string",
      "enum": [
        "all_done",
        "all_done_setup_success",
        "all_failed",
        "all_skipped",
        "all_success",
        "always",
        "none_failed",
        "none_failed_min_one_success",
        "none_skipped",
        "one_done",
        "one_failed",
        "one_success"
      ],
      "description": "Trigger rule for this step (default: all_success)"
    }
  },
  "required": [
    "blueprint",
    "version",
    "conn_id"
  ],
  "title": "run_sql",
  "type": "object",
  "templateType": "blueprint",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
