{
  "properties": {
    "http_conn_id": {
      "default": "http_default",
      "description": "Airflow HTTP connection ID holding the base URL.",
      "title": "Http Conn Id",
      "type": "string"
    },
    "endpoint": {
      "description": "Path appended to the connection's base URL, e.g. `/v1/orders`.",
      "title": "Endpoint",
      "type": "string"
    },
    "method": {
      "default": "GET",
      "description": "HTTP method.",
      "enum": [
        "GET",
        "POST",
        "PUT",
        "DELETE"
      ],
      "title": "Method",
      "type": "string"
    },
    "data": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Request body (for POST/PUT) or query string (for GET).",
      "title": "Data"
    },
    "log_response": {
      "default": true,
      "description": "Log the response body. The response is also pushed to XCom.",
      "title": "Log Response",
      "type": "boolean"
    },
    "blueprint": {
      "type": "string",
      "const": "http_api_extract",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Steps that must complete before this step runs",
      "default": []
    },
    "trigger_rule": {
      "type": "string",
      "enum": [
        "all_done",
        "all_done_setup_success",
        "all_failed",
        "all_skipped",
        "all_success",
        "always",
        "none_failed",
        "none_failed_min_one_success",
        "none_skipped",
        "one_done",
        "one_failed",
        "one_success"
      ],
      "description": "Trigger rule for this step (default: all_success)"
    }
  },
  "required": [
    "blueprint",
    "version",
    "endpoint"
  ],
  "title": "http_api_extract",
  "type": "object",
  "templateType": "blueprint",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
