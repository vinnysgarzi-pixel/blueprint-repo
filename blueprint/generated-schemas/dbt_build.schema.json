{
  "properties": {
    "project_dir": {
      "description": "Path to the dbt project, e.g. `/usr/local/airflow/dbt/my_project`.",
      "title": "Project Dir",
      "type": "string"
    },
    "command": {
      "default": "build",
      "description": "dbt command to execute. `build` runs models, tests, seeds, and snapshots together.",
      "enum": [
        "build",
        "run",
        "test",
        "seed",
        "snapshot"
      ],
      "title": "Command",
      "type": "string"
    },
    "select": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "dbt `--select` selector, e.g. `tag:nightly` or `my_model+`.",
      "title": "Select"
    },
    "target": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "dbt target/profile to use, e.g. `prod`.",
      "title": "Target"
    },
    "profiles_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Path to the dbt profiles directory. Defaults to the project directory.",
      "title": "Profiles Dir"
    },
    "full_refresh": {
      "default": false,
      "description": "Pass `--full-refresh` to rebuild incremental models.",
      "title": "Full Refresh",
      "type": "boolean"
    },
    "blueprint": {
      "type": "string",
      "const": "dbt_build",
      "description": "The blueprint template to use"
    },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "The blueprint version"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Steps that must complete before this step runs",
      "default": []
    },
    "trigger_rule": {
      "type": "string",
      "enum": [
        "all_done",
        "all_done_setup_success",
        "all_failed",
        "all_skipped",
        "all_success",
        "always",
        "none_failed",
        "none_failed_min_one_success",
        "none_skipped",
        "one_done",
        "one_failed",
        "one_success"
      ],
      "description": "Trigger rule for this step (default: all_success)"
    }
  },
  "required": [
    "blueprint",
    "version",
    "project_dir"
  ],
  "title": "dbt_build",
  "type": "object",
  "templateType": "blueprint",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
